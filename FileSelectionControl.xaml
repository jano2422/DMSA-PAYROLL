<UserControl x:Class="FileSelectionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="600">
    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Text -->
        <TextBlock Text="Select DTR File" FontSize="18" FontWeight="Bold"
                   Margin="10" HorizontalAlignment="Center"/>

        <!-- ListBox for File List -->
        <ListBox x:Name="FileListBox" Grid.Row="1" Margin="10" Background="LightYellow"
                 BorderThickness="1" BorderBrush="Gray" FontSize="14" SelectionMode="Single">
        </ListBox>

        <!-- Buttons Panel -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button x:Name="BtnReselectFolder" Content="Reselect Folder" Width="150" Margin="5"
                    Background="Maroon" Foreground="White" FontSize="14"/>
            <Button x:Name="BtnCancel" Content="Cancel" Width="100" Margin="5"
                    Background="Black" Foreground="Yellow" FontSize="14"/>
        </StackPanel>
    </Grid>
</UserControl>
