<Window x:Class="DMSA_System.ScheduleManager"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:dmsa="clr-namespace:DMSA_System"
        Title="Shift Scheduler"
        WindowState="Maximized"
        MinHeight="600"
        MinWidth="800"
        Background="{DynamicResource MaterialDesign.Brush.Background}">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Use Material Design 3 Defaults -->
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml"/>

                <!-- Define Primary and Secondary Colors -->
                <materialDesign:BundledTheme BaseTheme="Light" PrimaryColor="DeepPurple" SecondaryColor="Lime" />
            </ResourceDictionary.MergedDictionaries>

            <dmsa:ShiftEndDayConverter x:Key="ShiftEndDayConverter"/>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header Section -->
        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,10">
            <TextBlock Text="Shift Scheduler" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource MaterialDesign.Brush.Primary}"/>
        </StackPanel>

        <!-- Employee and Payroll Section -->
        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Employee Info -->
            <materialDesign:Card Grid.Column="0" Padding="10">
                <GroupBox Header="Employee Information" FontSize="16">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Employee ID:" FontWeight="Bold" Grid.Row="0" Grid.Column="0" Margin="5"/>
                        <TextBlock Text="{Binding SelectedEmployee.EmployeeID}" Grid.Row="0" Grid.Column="1" Margin="5"/>
                        <TextBlock Text="Name:" FontWeight="Bold" Grid.Row="0" Grid.Column="2" Margin="5"/>
                        <TextBlock Text="{Binding SelectedEmployee.Name}" Grid.Row="0" Grid.Column="3" Margin="5"/>
                        <TextBlock Text="Department:" FontWeight="Bold" Grid.Row="1" Grid.Column="0" Margin="5"/>
                        <TextBlock Text="{Binding SelectedEmployee.Department}" Grid.Row="1" Grid.Column="1" Margin="5"/>
                        <TextBlock Text="Position:" FontWeight="Bold" Grid.Row="1" Grid.Column="2" Margin="5"/>
                        <TextBlock Text="{Binding SelectedEmployee.Position}" Grid.Row="1" Grid.Column="3" Margin="5"/>
                    </Grid>
                </GroupBox>
            </materialDesign:Card>

            <!-- Search and Payroll -->
            <StackPanel Grid.Column="1" Margin="20,0,0,0">
                <TextBlock Text="Search Employee:" FontWeight="Bold" Margin="0,0,0,5"/>
                <TextBox x:Name="EmployeeSearchTextBox"
                         Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         materialDesign:HintAssist.Hint="Enter employee name"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         Width="250"
                         Margin="0,0,0,10"/>

                <!-- Employee Search Popup -->
                <Popup x:Name="EmployeeSearchPopup" 
                       IsOpen="{Binding IsEmployeeSearchPopupOpen, Mode=TwoWay}"
                       PlacementTarget="{Binding ElementName=EmployeeSearchTextBox}"
                       Placement="Bottom" 
                       StaysOpen="True"
                       AllowsTransparency="True">
                    <Border Background="White" BorderBrush="Gray" BorderThickness="1">
                        <ListBox x:Name="EmployeeListBox"
                                 ItemsSource="{Binding FilteredEmployees}"
                                 SelectedItem="{Binding SelectedEmployee, Mode=TwoWay}"
                                 MinWidth="{Binding ActualWidth, ElementName=EmployeeSearchTextBox}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Vertical" Margin="5">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding EmployeeID}" FontSize="12"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </Popup>

                <ComboBox x:Name="PayrollPeriodComboBox"
                          SelectedIndex="{Binding PayrollPeriodIndex, Mode=TwoWay}"
                          Style="{StaticResource MaterialDesignOutlinedComboBox}"
                          Width="250"
                          Margin="0,10,0,0">
                    <ComboBoxItem Content="1st Cut-Off (Days 1-15)"/>
                    <ComboBoxItem Content="2nd Cut-Off (Days 16-31)"/>
                </ComboBox>
            </StackPanel>
        </Grid>

        <!-- Schedule DataGrid -->
        <DataGrid x:Name="ScheduleDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  ItemsSource="{Binding ScheduleTable}"
                  CanUserAddRows="False"
                  Margin="0,10,0,10"
                  VerticalAlignment="Stretch"
                  HorizontalAlignment="Stretch"
                  RowHeight="50"
                  Style="{StaticResource MaterialDesignDataGrid}">
            <DataGrid.Resources>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="10"/>
                    <Setter Property="VerticalContentAlignment" Value="Center"/>
                    <Setter Property="HorizontalContentAlignment" Value="Center"/>
                </Style>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="{DynamicResource MaterialDesign.Brush.Primary}"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="10"/>
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Day Number" Binding="{Binding DayNumber}" IsReadOnly="True" Width="70"/>
                <DataGridTemplateColumn Header="Shift Start (HH:MM)" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <materialDesign:TimePicker Width="140" Height="40"
                                                       SelectedTime="{Binding ShiftStartTime, Mode=TwoWay}"
                                                       Margin="4,0,0,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="Shift End (HH:MM)" Width="220">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <materialDesign:TimePicker Width="140" Height="40"
                                                       SelectedTime="{Binding ShiftEndTime, Mode=TwoWay}"
                                                       Margin="8,0,0,0"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Shift Type" Binding="{Binding ShiftType}" IsReadOnly="True" Width="100"/>
                <DataGridTextColumn Header="Total Hours" Binding="{Binding TotalHours}" IsReadOnly="True" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button Content="Save Schedule"
                    Command="{Binding SaveScheduleCommand}"
                    Margin="5"
                    Width="200"
                    Height="50"
                    Style="{StaticResource MaterialDesignOutlinedButton}"/>
        </StackPanel>
    </Grid>
</Window>
